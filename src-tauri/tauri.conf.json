{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyMedia",
  "version": "0.1.0",
  "identifier": "com.easymedia.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EasyMedia",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"]
  },
  "plugins": {}
}
